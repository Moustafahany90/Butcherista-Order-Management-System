# ── Firebase Client Config (safe for client-side) ──
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ── Seed Script ──
# Required: ADMIN_PASSWORD=your-strong-password

# ── Firebase Functions Secrets (set via CLI, NOT in .env) ──
# These are configured with: firebase functions:secrets:set SECRET_NAME
#   TELEGRAM_BOT_TOKEN     — Telegram bot token for delivery alerts
#   TELEGRAM_CHAT_ID       — Telegram chat/group ID for delivery alerts
#   SUPER_ADMIN_UID        — Super admin UID for elevated access
#   BOOTSTRAP_KEY          — Key used by bootstrapCompany callable function
